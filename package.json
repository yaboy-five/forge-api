{
  "name": "forge-api",
  "version": "1.0.0",
  "description": "Charming Leather Bootcamp - Production grade Node.js project",
  "main": "index.js",
  "engines": {
    "node": ">=21.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "test:unit": "jest tests/unit --runInBand",
    "test:integration": "jest tests/integration --runInBand",
    "test:e2e": "jest tests/e2e --runInBand",
    "test:coverage": "jest --coverage --runInBand"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yaboy-five/forge-api.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/yaboy-five/forge-api/issues"
  },
  "homepage": "https://github.com/yaboy-five/forge-api#readme",
  "dependencies": {
    "axios": "^1.17.0",
    "dotenv": "^16.3.1",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "winston": "^3.19.0",
    "winston-mongodb": "^7.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  }
}
